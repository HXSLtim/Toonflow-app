# 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# 应用配置
NODE_ENV=prod
PORT=60000

# Docker 配置
HTTP_PORT=80
API_PORT=60000
TAG=latest
GIT=github

# 数据库配置（如果使用外部数据库）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=toonflow
# DB_USER=toonflow
# DB_PASSWORD=your_password

# AI 服务配置
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
# DEEPSEEK_API_KEY=your_deepseek_key

# 日志配置
LOG_LEVEL=info

# 监控与告警配置
ALERT_ENABLED=false
# ALERT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# ALERT_EMAIL=admin@example.com

# 安全配置
# JWT_SECRET 必须至少 32 个字符，生产环境必须修改为强随机字符串
# 可使用命令生成: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_MIN_32_CHARS_RANDOM_STRING_REQUIRED
# SESSION_SECRET=your_session_secret
# CORS 允许的前端域名，多个用逗号分隔
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# 资源限制
MAX_MEMORY=2G
MAX_CPU=2

# 时区
TZ=Asia/Shanghai
