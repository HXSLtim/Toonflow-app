{
  "name": "toonflow-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "Toonflow monorepo workspace (web + api)",
  "scripts": {
    "dev:api": "npm --prefix api run dev",
    "dev:web": "npm --prefix web run dev",
    "lint:api": "npm --prefix api run lint",
    "lint:web": "npm --prefix web run lint",
    "lint": "npm run lint:api && npm run lint:web",
    "test:api": "npm --prefix api run test",
    "test": "npm run test:api",
    "build:api": "npm --prefix api run build",
    "build:web": "npm --prefix web run build",
    "build": "npm run build:api && npm run build:web"
  }
}
